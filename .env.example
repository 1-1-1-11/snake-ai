PORT=3000

# Text generation via Zhipu GLM
ZHIPU_API_KEY=sk-xxx-your-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_TEXT_MODEL=glm-4.6v

# Text generation via MiniMax Anthropic-compatible endpoint
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_TEXT_MODEL=MiniMax-M2.7

# Image generation via Volcengine Ark / Doubao Seedream
VOLC_IMAGE_API_KEY=91900d27-9d38-4254-8a31-1d23825f98c6
VOLC_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com
VOLC_IMAGE_MODEL=doubao-seedream-4-5-251128
VOLC_IMAGE_RESPONSE_FORMAT=url
VOLC_IMAGE_SIZE=2K
VOLC_IMAGE_WATERMARK=true